<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <title>เข้าสู่ระบบ</title>
  <link rel="stylesheet" href="/styles/login.css">
  <link href="https://fonts.googleapis.com/css2?family=Kanit&display=swap" rel="stylesheet">
</head>
<body>
  <div class="login-container">
    <div class="login-left"></div>
    <div class="login-right">
      <h2>เข้าสู่ระบบ</h2>
      
      <form action="/login" method="POST">
        <label for="email">อีเมลผู้ใช้งาน</label>
        <input type="email" name="email" placeholder="อีเมลผู้ใช้งาน" required>

        <label for="password">รหัสผ่าน</label>
        <input type="password" name="password" placeholder="รหัสผ่าน" required><br>

        <button type="submit">เข้าสู่ระบบ</button>
      </form>

      <p class="or-text">หรือเข้าสู่ระบบด้วย</p>
      <a href="/auth/google">
        <img src="/images/google.png" alt="เข้าสู่ระบบด้วย Google" class="google-icon">
      </a>

      <p class="register-text">
        หากคุณยังไม่มีบัญชีสามารถ <a href="/register">สมัครสมาชิก</a> ได้ที่นี้
      </p>
    </div>
  </div>
</body>
</html>
