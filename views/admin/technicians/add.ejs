<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>เพิ่มข้อมูลช่าง</title>
  <link rel="stylesheet" href="/styles/index_admin.css">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Kanit&display=swap" rel="stylesheet">
  <!-- Flatpickr CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

  <style>
    .service-item { margin-bottom: 5px; }
    .service-list { margin: 10px 0; }
  </style>
</head>
<body>
  <header class="top-navbar">
    <div class="left-section">
      <span class="material-icons menu-icon">menu</span>
      <a href="/admin/dashboard" class="logo">
        <img src="/images/logo.png" alt="HandyX Logo" class="logo-img">
      </a>
    </div>
    <!--
    <div class="right-section">
      <i class="material-icons profile-icon">account_circle</i>
    </div>
    -->
  </header>
  <div class="container">
    <aside class="sidebar">
      <nav>
        <ul>
          <li class="<%= currentPage === 'dashboard' ? 'active' : '' %>">
            <a href="/admin/dashboard"><i class="material-icons">dashboard</i>หน้าหลัก</a>
          </li>
          <li class="<%= currentPage === 'technicians' ? 'active' : '' %>">
            <a href="/admin/technicians"><i class="material-icons">build</i>ระบบจัดการฐานข้อมูลช่าง</a>
          </li>
          <li class="<%= currentPage === 'users' ? 'active' : '' %>">
            <a href="/admin/users"><i class="material-icons">people</i>ระบบจัดการฐานข้อมูลผู้ใช้</a>
          </li>
          <li class="<%= currentPage === 'service_categories' ? 'active' : '' %>">
            <a href="/admin/service-categories"><i class="material-icons">category</i>จัดการหมวดหมู่บริการ</a>
          </li>
          <li class="<%= currentPage === 'services' ? 'active' : '' %>">
            <a href="/admin/services"><i class="material-icons">miscellaneous_services</i>จัดการบริการ</a>
          </li>
          <li class="<%= currentPage === 'bookings' ? 'active' : '' %>">
            <a href="/admin/bookings"><i class="material-icons">event_note</i>ตรวจสอบการจอง</a>
          </li>
          <li class="<%= currentPage === 'payments' ? 'active' : '' %>">
            <a href="/admin/payments"><i class="material-icons">payment</i>ตรวจสอบการชำระเงิน</a>
          </li>
          <li>
            <a href="/admin/logout"><i class="material-icons">logout</i>ออกจากระบบ</a>
          </li>
        </ul>
      </nav>
    </aside>
    <main class="main-content">
      <div class="content">
        <!-- กล่อง list-card -->
        <div class="list-card">

          <div class="page-header">
            <h2> เพิ่มข้อมูลพนักงานช่าง</h2>
          </div>

          <form id="technicianForm" action="/admin/technicians/add" method="POST" enctype="multipart/form-data" class="technician-form">
            <div class="technician-form-container">

              <!-- ช่องใส่รูป -->
              <div class="technician-form-photo">
                <label for="photoInput" class="technician-form-photo-box" id="photoPreview">
                  คลิกเพื่อเลือกรูป
                </label>
                <input type="file" id="photoInput" name="photo" accept="image/*" hidden>
              </div>


              <!-- ช่องกรอกข้อมูล -->
              <div class="technician-form-fields">
                <div class="technician-form-row">
                  <div class="technician-form-group">
                    <label>คำนำหน้า</label>
                    <select name="prefix" required>
                      <option value="">-- เลือกคำนำหน้า --</option>
                      <option value="นาย">นาย</option>
                      <option value="นาง">นาง</option>
                      <option value="นางสาว">นางสาว</option>
                    </select>
                  </div>
                </div>


                <div class="technician-form-row">
                  <div class="technician-form-group">
                    <label>ชื่อ</label>
                    <input type="text" name="first_name" placeholder="ชื่อ" required>
                  </div>
                  <div class="technician-form-group">
                    <label>นามสกุล</label>
                    <input type="text" name="last_name" placeholder="นามสกุล" required>
                  </div>
                </div>

                <div class="technician-form-row">
                  <div class="technician-form-group">
                    <label>วัน-เดือน-ปีเกิด</label>
                    <input type="text" name="birth_date" id="birth_date" placeholder="วัน-เดือน-ปีเกิด" required>
                  </div>
                </div>


                <div class="technician-form-row">
                  <div class="technician-form-group">
                    <label>เบอร์โทร</label>
                    <input type="text" name="phone" placeholder="เบอร์โทร" maxlength="10" oninput="validatePhone(this)" required>
                  </div>

                  <div class="technician-form-group">
                    <label>อีเมล</label>
                    <input type="email" name="email" placeholder="อีเมล" required>
                  </div>
                </div>

                <div class="technician-form-row">
                  <div class="technician-form-group">
                    <label>ที่อยู่</label>
                    <textarea name="address" placeholder="ที่อยู่" required></textarea>
                  </div>
                </div>


                <h3>การทำงาน</h3>
                <div class="technician-form-row">
                  <div class="technician-form-group">
                    <label>แผนก</label>
                    <select name="category_id" id="category_id" required>
                      <option value="" disabled selected>-- กรุณาเลือกแผนก --</option>
                      <% categories.forEach(category => { %>
                        <option value="<%= category.id %>"><%= category.name %></option>
                      <% }) %>
                    </select>
                  </div>

                  <div class="technician-form-group">
                    <label>วัน-เดือน-ปีที่เข้าทำงาน</label>
                    <input type="text" name="start_date" id="start_date" placeholder="วัน-เดือน-ปีที่เข้าทำงาน" required >
                  </div>
                </div>
                
                <div class="technician-form-row">
                  <div class="technician-form-group">
                  <label>บริการที่ช่างสามารถทำได้</label>
                  <p id="warning-message" style="color:red; display:none; margin-top:5px;"></p>
                    <div class="service-grid">
                      <% services.forEach(service => { %>
                        <label class="service-option service-item" data-category="<%= service.service_category_id %>">
                          <input type="checkbox" name="service_ids[]" value="<%= service.id %>">
                          <span><%= service.name %></span>
                        </label>
                      <% }) %>
                    </div>
                  </div>

                </div>
                

                <h3>สิทธิการเข้าใช้ระบบ</h3>
                <div class="technician-form-row">
                  <div class="technician-form-group">
                    <label>อีเมล:</label>
                    <input type="email" name="login_email" placeholder="อีเมล" required >
                  </div>
                  <div class="technician-form-group">
                    <label>รหัสผ่าน:</label>
                    <input type="password" name="password" placeholder="รหัสผ่าน" required >
                  </div>
                </div>
                
                <br>
                  <div class="technician-btn-group">
                    <button class="technician-btn-submit" >บันทึก</button> 
                  </div>
                
                
              </div>
            </div>
          </form>
        </div>
      </div>
    </main>
  </div>
  
  <script>
document.addEventListener('DOMContentLoaded', function () {
  const form = document.getElementById('technicianForm'); // form ต้องมี id="technicianForm"
  const warningMessage = document.getElementById('warning-message');
  const categorySelect = document.getElementById('category_id');
  const serviceItems = document.querySelectorAll('.service-item');

  // ฟังก์ชันกรองบริการตาม category
  function filterServicesByCategory(categoryId) {
    if (!categoryId) {
      serviceItems.forEach(item => {
        item.style.display = 'none';
        item.querySelector('input[type="checkbox"]').checked = false;
      });
      if (warningMessage) {
        warningMessage.textContent = 'กรุณาเลือกแผนกก่อนเลือกบริการ';
        warningMessage.style.display = 'block';
      }
      return;
    }
    if (warningMessage) warningMessage.style.display = 'none';
    serviceItems.forEach(item => {
      if (item.dataset.category === String(categoryId)) {
        item.style.display = 'block';
      } else {
        item.style.display = 'none';
        item.querySelector('input[type="checkbox"]').checked = false;
      }
    });
  }

  filterServicesByCategory('');
  categorySelect.addEventListener('change', function () {
    filterServicesByCategory(this.value);
  });

  // ตรวจสอบก่อน submit
  form.addEventListener('submit', function(e) {
    const checked = document.querySelectorAll('input[name="service_ids[]"]:checked');
    if (checked.length === 0) {
      e.preventDefault(); // ✅ หยุด form ไม่ submit
      warningMessage.textContent = 'กรุณาเลือกบริการอย่างน้อย 1 รายการ';
      warningMessage.style.display = 'block';
      warningMessage.scrollIntoView({ behavior: 'smooth' }); // เลื่อนมาดูข้อความ
    }
  });
});
</script>



  <!-- Flatpickr -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
  <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/th.js"></script>
  

<script>
  function formatToBuddhist(date) {
    const day = date.getDate();
    const monthNames = [
      'มกราคม', 'กุมภาพันธ์', 'มีนาคม', 'เมษายน', 'พฤษภาคม', 'มิถุนายน',
      'กรกฎาคม', 'สิงหาคม', 'กันยายน', 'ตุลาคม', 'พฤศจิกายน', 'ธันวาคม'
    ];
    const monthName = monthNames[date.getMonth()];
    const year = date.getFullYear() + 543;
    return `${day} ${monthName} ${year}`;
  }

  flatpickr("#birth_date", {
    locale: "th",
    altInput: true,
    altFormat: "j F Y",
    dateFormat: "Y-m-d",
    maxDate: "today", //maxDate: new Date().fp_incr(-18 * 365), จำกัดอายุขั้นต่ำ 18 ปี
    onChange: function(selectedDates, dateStr, instance) {
      if (selectedDates.length > 0 && instance.altInput) {
        instance.altInput.value = formatToBuddhist(selectedDates[0]);
      }
    }
  });

  flatpickr("#start_date", {
    locale: "th",
    altInput: true,
    altFormat: "j F Y",
    dateFormat: "Y-m-d",
    maxDate: "today",
    onChange: function(selectedDates, dateStr, instance) {
      if (selectedDates.length > 0 && instance.altInput) {
        instance.altInput.value = formatToBuddhist(selectedDates[0]);
      }
    }
  });
</script>

  <script>
    const photoInput = document.getElementById('photoInput');
    const photoPreview = document.getElementById('photoPreview');

    photoInput.addEventListener('change', function () {
      const file = this.files[0];
      if (file) {
        const reader = new FileReader();
        reader.onload = function (e) {
          photoPreview.style.backgroundImage = `url(${e.target.result})`;
          photoPreview.textContent = ''; // ลบข้อความ "คลิกเพื่อเลือกรูป"
        };
        reader.readAsDataURL(file);
      }
    });
  </script>

<script>
  // เบอร์โทร
function validatePhone(input) {
  // ให้พิมพ์เฉพาะตัวเลข
  input.value = input.value.replace(/[^0-9]/g, '');

  if (input.value.length === 10) {
    const phone = input.value;

    // ต้องขึ้นต้นด้วย 06, 08, 09 เท่านั้น
    const validPattern = /^0(6|8|9)\d{8}$/;

    // ต้องไม่ใช่เลขซ้ำทั้ง 10 ตัว เช่น 0000000000
    const notRepeated = !/^(\d)\1{9}$/.test(phone);

    if (!validPattern.test(phone) || !notRepeated) {
      alert("กรุณากรอกเบอร์โทรศัพท์ให้ถูกต้อง");
      input.value = "";
    }
  }
}
</script>


</body>
</html>
