<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>ระบบจัดการฐานข้อมูลผู้ใช้</title>
  <link rel="stylesheet" href="/styles/index_admin.css">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Kanit&display=swap" rel="stylesheet">
</head>
<body>
    <header class="top-navbar">
        <div class="left-section">
        <span class="material-icons menu-icon">menu</span>
            <a href="/admin/dashboard" class="logo">
                <img src="/images/logo.png" alt="HandyX Logo" class="logo-img">
            </a>
        </div>
        <!--
    <div class="right-section">
      <i class="material-icons profile-icon">account_circle</i>
    </div>
    -->
    </header>
    <div class="container">
        <aside class="sidebar">
            <nav>
                <ul>
                    <li class="<%= currentPage === 'dashboard' ? 'active' : '' %>">
                        <a href="/admin/dashboard"><i class="material-icons">dashboard</i>หน้าหลัก</a>
                    </li>
                    <li class="<%= currentPage === 'technicians' ? 'active' : '' %>">
                        <a href="/admin/technicians"><i class="material-icons">build</i>ระบบจัดการฐานข้อมูลช่าง</a>
                    </li>
                    <li class="<%= currentPage === 'users' ? 'active' : '' %>">
                        <a href="/admin/users"><i class="material-icons">people</i>ระบบจัดการฐานข้อมูลผู้ใช้</a>
                    </li>
                    <li class="<%= currentPage === 'service_categories' ? 'active' : '' %>">
                        <a href="/admin/service-categories"><i class="material-icons">category</i>จัดการหมวดหมู่บริการ</a>
                    </li>
                    <li class="<%= currentPage === 'services' ? 'active' : '' %>">
                        <a href="/admin/services"><i class="material-icons">miscellaneous_services</i>จัดการบริการ</a>
                    </li>
                    <li class="<%= currentPage === 'bookings' ? 'active' : '' %>">
                        <a href="/admin/bookings"><i class="material-icons">event_note</i>ตรวจสอบการจอง</a>
                    </li>
                    <li class="<%= currentPage === 'payments' ? 'active' : '' %>">
                        <a href="/admin/payments"><i class="material-icons">payment</i>ตรวจสอบการชำระเงิน</a>
                    </li>
                    <li>
                        <a href="/admin/logout"><i class="material-icons">logout</i>ออกจากระบบ</a>
                    </li>
                </ul>
            </nav>
        </aside>

        <main class="main-content">
            <div class="content">
                <div class="list-card">
                    <h1>ระบบจัดการฐานข้อมูลผู้ใช้</h1>
                    <table class="tech-table">
                        <thead>
                            <tr>
                                <th>ลำดับที่</th>
                                <th>ชื่อ</th>
                                <th>นามสกุล</th>
                                <th>อีเมล</th>
                                <th>สถานะ</th>
                                <th>จัดการ</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% users.forEach((user,index) => { %>
                                <tr>
                                    <td><%= index + 1 %></td>
                                    <td><%= user.first_name || '-' %></td>
                                    <td><%= user.last_name || '' %></td>
                                    <td><%= user.email %></td>
                                    <td><%= user.role %></td>
                                    <td>
                                        <div class="btn-group">
                                            <button 
                                                class="btn-edit" 
                                                onclick="openEditModal('<%= user.profile_id %>', '<%= user.first_name %>', '<%= user.last_name %>', '<%= user.email %>', '<%= user.role %>')">
                                                แก้ไข
                                            </button>
                                              <button class="btn-deactivate" onclick="deactivateUser('<%= user.profile_id %>')">ปิดการใช้งาน</button>
                                        </div>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </main>
    </div>
    <!-- Modal แก้ไขข้อมูล -->
    <div id="editModal" class="modal-list">
        <div class="modal-list-content">
            <span class="modal-list-close" onclick="closeEditModal()">&times;</span>
            <h2>แก้ไขข้อมูลผู้ใช้</h2>

            <form id="editUserForm" method="POST" action="/admin/users/update">
                <input type="hidden" name="profile_id" id="editProfileId">
                
                <label class="modal-list-label">ชื่อ</label>
                <input type="text" name="first_name" id="editFirstName">
            

                <label class="modal-list-label">นามสกุล</label>
                <input type="text" name="last_name" id="editLastName">

                <label class="modal-list-label">อีเมล</label>
                <input type="email" name="email" id="editEmail">

                <label class="modal-list-label">สถานะ</label>
                <select name="role" id="editRole">
                    <option value="user">user</option>
                    <option value="admin">admin</option>
                </select>

                <div class="btn-row">
                    <button type="submit" class="btn-save">บันทึก</button>
                </div>
                
            </form>
        </div>
    </div>

<script>
  function openEditModal(id, first, last, email, role) {
    document.getElementById('editModal').style.display = 'block';
    document.getElementById('editProfileId').value = id;
    document.getElementById('editFirstName').value = first || '';
    document.getElementById('editLastName').value = last || '';
    document.getElementById('editEmail').value = email || '';
    document.getElementById('editRole').value = role || 'user';
  }

  function closeEditModal() {
    document.getElementById('editModal').style.display = 'none';
  }

  // ปิด modal ถ้าคลิกพื้นหลัง
  window.onclick = function(e) {
    const modal = document.getElementById('editModal');
    if (e.target === modal) {
      closeEditModal();
    }
  };

    async function deactivateUser(profile_id) {
        if (!confirm('คุณต้องการปิดการใช้งานผู้ใช้นี้หรือไม่?')) return;

        try {
            const res = await fetch('/admin/users/deactivate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ profile_id })
            });

            const message = await res.text();  //ข้อความจาก js

            if (res.ok) {
                alert('ปิดการใช้งานผู้ใช้เรียบร้อย');
                location.reload();
            } else {
                alert(message ||'เกิดข้อผิดพลาด');
            }
        } catch (err) {
            console.error(err);
            alert('เกิดข้อผิดพลาดในการปิดการใช้งาน');
        }
    }

</script>

</body>
</html>