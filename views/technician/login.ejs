<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <title>เข้าสู่ระบบช่าง</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://fonts.googleapis.com/css2?family=Kanit&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles/index_technician.css">
</head>
<body>

  <div class="center-login">
    <div class="login-box">
      <h2>เข้าสู่ระบบช่าง</h2>

      <form action="/technician/login" method="POST">
        <div class="form-group">
          <label for="email">อีเมล</label>
          <input type="email" id="email" name="email" placeholder="อีเมล" required>
        </div>

        <div class="form-group">
          <label for="password">รหัสผ่าน</label>
          <input type="password" id="password" name="password" placeholder="รหัสผ่าน" required>
        </div>
        <button type="submit" class="btn-login">เข้าสู่ระบบ</button>
      </form>
      <a href="/select-login" class="btn-back-home">กลับไปที่ <span>หน้าแรก</span></a>

    </div>
    
  </div>

</body>
</html>
