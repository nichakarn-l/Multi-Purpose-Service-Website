<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <title>สมัครสมาชิก</title>
  <link rel="stylesheet" href="/styles/login.css">
  <link href="https://fonts.googleapis.com/css2?family=Kanit&display=swap" rel="stylesheet">
  <script>
    function validateForm() {
      const password = document.getElementById("password").value;
      const confirmPassword = document.getElementById("confirmPassword").value;

      if (password !== confirmPassword) {
        alert("รหัสผ่านไม่ตรงกัน");
        return false;
      }
      return true;
    }
  </script>
</head>
<body>
  <div class="login-container">
    <!-- ฝั่งซ้าย -->
    <div class="login-left"></div>

    <!-- ฝั่งขวา -->
    <div class="login-right">
      <h2>สมัครสมาชิก</h2>

      <form action="/register" method="POST" onsubmit="return validateForm()">
        <div class="form-group-row">
          
          <div class="form-group">
            <label for="first_name">ชื่อ</label>
            <input type="text" name="first_name" placeholder="ชื่อ" required>
          </div>
          <div class="form-group">
            <label for="last_name">นามสกุล</label>
            <input type="text" name="last_name" placeholder="นามสกุล" required>
          </div>
        </div>

        <label for="phone">เบอร์โทรศัพท์</label>
        <input type="text" name="phone" placeholder="เบอร์โทรศัพท์" required maxlength="10" oninput="validatePhone(this)">

        <label for="email">อีเมล</label>
        <input type="email" name="email" placeholder="อีเมล" required>

        <label for="password">รหัสผ่าน</label>
        <input type="password" id="password" name="password" placeholder="รหัสผ่าน" required>

        <label for="confirmPassword">ยืนยันรหัสผ่าน</label>
        <input type="password" id="confirmPassword" placeholder="ยืนยันรหัสผ่าน" required>
        <br>
        <button type="submit">สมัครสมาชิก</button>
      </form>

      <p class="or-text">หรือสมัครด้วย</p>

      <a href="/auth/google">
        <img src="/images/google.png" alt="สมัครด้วย Google" class="google-icon">
      </a>

      <p class="register-text">
        หากคุณมีบัญชีอยู่แล้ว <a href="/login">เข้าสู่ระบบ</a> ได้ที่นี่
      </p>
    </div>
  </div>

  
<script>
  // เบอร์โทร
function validatePhone(input) {
  // ให้พิมพ์เฉพาะตัวเลข
  input.value = input.value.replace(/[^0-9]/g, '');

  if (input.value.length === 10) {
    const phone = input.value;

    // ต้องขึ้นต้นด้วย 06, 08, 09 เท่านั้น
    const validPattern = /^0(6|8|9)\d{8}$/;

    // ต้องไม่ใช่เลขซ้ำทั้ง 10 ตัว เช่น 0000000000
    const notRepeated = !/^(\d)\1{9}$/.test(phone);

    if (!validPattern.test(phone) || !notRepeated) {
      alert("กรุณากรอกเบอร์โทรศัพท์ให้ถูกต้อง");
      input.value = "";
    }
  }
}
</script>

</body>
</html>
