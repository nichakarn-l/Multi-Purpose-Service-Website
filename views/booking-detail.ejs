<!DOCTYPE html>
<html lang="th">
<head>
  <meta charset="UTF-8">
  <title>การจองของฉัน</title>
  <link rel="stylesheet" href="/styles/index.css">
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Kanit&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
  <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<style>
  /* Modal Overlay */
  #rescheduleModal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
    justify-content: center;
    align-items: center;
    z-index: 9999;
  }

  #rescheduleModal.show {
    display: flex;
  }

  /* Modal Box */
  #rescheduleModal .modal-content {
    background: #fff;
    padding: 24px;
    width: 400px;
    border-radius: 12px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    font-family: 'Kanit', sans-serif;
    position: relative;
  }

  /* Close Button (X) */
  #rescheduleModal .close {
    position: absolute;
    top: 12px;
    right: 16px;
    font-size: 22px;
    cursor: pointer;
    color: #666;
  }

  #rescheduleModal .close:hover {
    color: #000;
  }

  #rescheduleModal h3 {
    text-align: center;
    margin-top: 0;
    font-size: 22px;
    color: #183C91;
    margin-bottom: 16px;
  }

  #rescheduleModal label {
    display: block;
    margin: 14px 0 6px;
    font-weight: bold;
    color: #333;
  }

  #rescheduleModal input,
  #rescheduleModal select {
    width: 100%;
    padding: 10px;
    font-size: 14px;
    border: 1px solid #ccc;
    border-radius: 6px;
  }

  /* Buttons */
  #rescheduleModal .form-buttons {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-top: 20px;
  }

  #rescheduleModal #rescheduleCancel,
  #rescheduleModal .btn-submit {
    padding: 8px 16px;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    font-weight: 500;
    font-size: 14px;
  }

  #rescheduleModal #rescheduleCancel {
    background: #ccc;
    color: #333;
  }

  #rescheduleModal #rescheduleCancel:hover {
    background: #aaa;
  }

  #rescheduleModal .btn-submit {
    background: #183C91;
    color: #fff;
  }

  #rescheduleModal .btn-submit:hover {
    background: #0d2c70;
  }
</style>

</head>
<body>
  <header class="navbar">
    <div class="container">
      <div class="navbar-left">
        <a href="/" class="logo">
          <img src="/images/logo.png" alt="HandyX Logo" class="logo">
        </a>
      </div>
      <div class="navbar-right">
        <div class="profile-dropdown">
          <img src="/images/profile.png" alt="Profile" class="icon profile-icon">
          <div class="dropdown-menu">
            <a href="/edit-profile">ข้อมูลส่วนตัว</a>
              <a href="/my-bookings">ประวัติการจอง</a>
              <a href="/reviews">รีวิวของฉัน</a>
              <a href="/logout">ออกจากระบบ</a>
          </div>
        </div>
      </div>
    </div>
  </header>

    <main class="container">
        <div class="breadcrumb">
        <a href="/">หน้าหลัก</a>
        <i class="fas fa-angle-right"></i>
        <a href="/my-bookings">ประวัติการจอง</a>
        
        </div>
        <div class="profile-page">
            <div class="profile-sidebar">
                <h3>บัญชีของฉัน</h3>
                <ul>
                    <li><a href="/edit-profile">ข้อมูลส่วนตัว</a></li>
                    <li><a href="/my-bookings" class="active">ประวัติการจอง</a></li>
                    <li><a href="/reviews">รีวิวของฉัน</a></li>
                </ul>
                <ul>
                    <li><a href="/logout" class="logout">ออกจากระบบ</a></li>
                </ul>
            </div>

            <div class="booking-detail-container">
                  <div class="booking-detail-content">
                    <!-- ปุ่มเลื่อน -->
                    <% if (canReschedule) { %>
                      <button class="btn-resched"
                              onclick="openCustomerRescheduleModal(<%= booking.id %>)">
                        เลื่อนวัน–เวลา
                      </button>
                    <% } %>


                    <!--  คอลัมน์ซ้าย: รายละเอียดการจอง -->
                    <div class="booking-info">
                        <h3>รายละเอียดการจอง</h3>
                        <p><strong>หมายเลขการจอง:</strong> <%= booking.id %></p>
                        <p><strong>รายละเอียด:</strong> <%= booking.service_name %></p>
                        <p><strong>ชื่อผู้จอง:</strong> <%= booking.user_fullname %></p>
                        <p><strong>วันนัดหมาย:</strong> 
                        <%= booking.booking_date.toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                        </p>
                        <p><strong>เวลานัดหมาย:</strong> <%= booking.booking_time.slice(0, 5) %> น.</p>

                        <h3>ข้อมูลช่าง</h3>
                        <p><strong>ชื่อ:</strong> <%= booking.tech_fullname %></p>
                        <p><strong>เบอร์โทรศัพท์:</strong> <%= booking.tech_phone || '-' %></p>

                        <h3>สถานะการจอง</h3>
                        <p><%= booking.status_text %></p>
                    </div>

                    

                    <% if (booking.status_text !== 'ยกเลิกโดยระบบ' && 
                          booking.status_text !== 'ยกเลิกโดยผู้ใช้' && 
                          booking.status_text !== 'ช่างไม่พร้อมให้บริการตามนัด' && 
                          booking.status_text !== 'กรุณาเลือกวัน-เวลาใหม่' && 
                          booking.status_text !== '-' ) { %>

                      <div class="status-timeline-vertical"> 
                        <%
                          const steps = [
                            'ดำเนินการจอง',
                            'ชำระมัดจำแล้ว',
                            'รอดำเนินการ',
                            'กำลังเนินการซ่อมแซม',
                            'ดำเนินการเสร็จสิ้น'
                          ];
                          const currentIndex = steps.indexOf(booking.status_text);
                        %>

                        <% steps.forEach((step, index) => { %>
                          <div class="status-item">
                            <div class="status-circle-wrapper">
                              <div class="
                                status-circle 
                                <%= index < currentIndex ? 'completed' : 
                                    index === currentIndex ? 'active' : 'upcoming' %>
                              "></div>

                              <% if (index < steps.length - 1) { %>
                                <div class="status-line"></div>
                              <% } %>
                            </div>
                            <span class="status-text"><%= step %></span>
                          </div>
                        <% }) %>
                      </div>

                    <% } %>
                  </div>

                  <input type="hidden" id="service_id" value="<%= booking.service_id %>">
                  <input type="hidden" id="technician_id" value="<%= booking.technician_id %>">

                  <!-- เลื่อนวันเวลานัด -->
                  <div id="rescheduleModal" class="modal">
                    <div class="modal-content">
                      <span class="close" id="rescheduleClose">&times;</span>

                      <h3>เลื่อนวัน-เวลา</h3>

                      <form id="rescheduleForm">
                        <input type="hidden" name="booking_id" id="reschedule_booking_id">

                        <label>เลือกวันที่ใหม่:</label>
                        <input type="text" id="reschedule_date_display" required placeholder="วัน/เดือน/ปี">
                        <input type="hidden" id="reschedule_date" name="new_date">

                        <label>เลือกเวลาที่ใหม่:</label>
                        <select id="reschedule_time" name="new_time" required>
                          <option value="">-- กรุณาเลือกเวลา --</option>
                        </select>

                        
                        <div class="reschedule-note">
                          <i class="material-icons">warning</i>
                          สามารถขอเลื่อนวัน–เวลาได้เพียง 1 ครั้งต่อการจอง
                        </div>

                        <div class="form-buttons">
                          <button type="button" id="rescheduleCancel">ยกเลิก</button>
                          <button type="submit" class="btn-submit">บันทึก</button>
                        </div>
                      </form>
                    </div>
                  </div>

            </div>

          </div>
    </main>

<script>
  document.addEventListener("DOMContentLoaded", function () {

    const modal = document.getElementById("rescheduleModal");
    const bookingIdInput = document.getElementById("reschedule_booking_id");
    const dateDisplay = document.getElementById("reschedule_date_display");
    const dateHidden = document.getElementById("reschedule_date");
    const timeSelect = document.getElementById("reschedule_time");

    const serviceElement = document.getElementById("service_id");
    const technicianElement = document.getElementById("technician_id");

    const serviceId = serviceElement ? serviceElement.value : null;
    const technicianId = technicianElement ? technicianElement.value : null;

    //  แสดงวันที่แบบไทย พ.ศ.
    function formatThaiDate(dateObj) {
      const months = [
        "มกราคม","กุมภาพันธ์","มีนาคม","เมษายน","พฤษภาคม","มิถุนายน",
        "กรกฎาคม","สิงหาคม","กันยายน","ตุลาคม","พฤศจิกายน","ธันวาคม"
      ];
      const d = dateObj.getDate();
      const m = months[dateObj.getMonth()];
      const y = dateObj.getFullYear() + 543;
      return `${d} ${m} ${y}`;
    }

    // เปิด modal
    window.openCustomerRescheduleModal = function(bookingId) {
      bookingIdInput.value = bookingId;
      modal.classList.add("show");

      dateHidden.value = '';
      timeSelect.innerHTML = '<option value="">-- กรุณาเลือกเวลา --</option>';
    };

    function closeModal() {
      modal.classList.remove("show");
    }

    document.getElementById("rescheduleClose").addEventListener("click", closeModal);
    document.getElementById("rescheduleCancel").addEventListener("click", closeModal);

    //  Flatpickr
    flatpickr(dateDisplay, {
      dateFormat: "Y-m-d",
      altInput: true,
      altFormat: "d F Y",
      minDate: "today",
      maxDate: new Date().fp_incr(30),

      onChange: async function(selectedDates) {

        if (!selectedDates.length) return;

        const selectedDate = selectedDates[0];

        // ✅ แสดงผลแบบไทย (พ.ศ.)
        this.altInput.value = formatThaiDate(selectedDate);

        // ✅ เก็บค่า ISO ส่ง backend
        const yyyy = selectedDate.getFullYear();
        const mm = String(selectedDate.getMonth()+1).padStart(2,'0');
        const dd = String(selectedDate.getDate()).padStart(2,'0');
        const isoDate = `${yyyy}-${mm}-${dd}`;

        dateHidden.value = isoDate;

        let url = `/available-times?date=${isoDate}&service_id=${serviceId}`;

        if (bookingIdInput.value)
          url += `&exclude_booking_id=${bookingIdInput.value}`;

        const response = await fetch(url);
        const times = await response.json();

        timeSelect.innerHTML = '<option value="">-- กรุณาเลือกเวลา --</option>';

        times.forEach(({ time, booked }) => {

          const option = document.createElement("option");

          const normalizedTime = time.slice(0,5); // 09:00
          option.value = normalizedTime;
          option.textContent = normalizedTime;

          const now = new Date();
          const todayISO = now.toISOString().split("T")[0];
          const isToday = isoDate === todayISO;

          // ===== เต็มแล้ว =====
          if (booked) {
            option.disabled = true;
            option.textContent += ' (เต็มแล้ว)';
          }

          // ===== เวลาผ่านแล้ว =====
          else if (isToday) {

            const [h, m] = normalizedTime.split(':').map(Number);

            const currentMinutes = now.getHours() * 60 + now.getMinutes();
            const slotMinutes = h * 60 + m;

            if (slotMinutes <= currentMinutes) {
              option.disabled = true;
              option.style.color = 'gray';
            }
          }

          timeSelect.appendChild(option);

        });

      }
    });

    // submit
    document.getElementById("rescheduleForm").addEventListener("submit", async function(e) {

      e.preventDefault();

      const booking_id = bookingIdInput.value;
      const new_date = dateHidden.value;
      const new_time = timeSelect.value;

      if (!new_date || !new_time) {
        alert("กรุณาเลือกวันและเวลาใหม่");
        return;
      }

      const response = await fetch("/customer/reschedule", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ booking_id, new_date, new_time })
      });

      const result = await response.json();

      if (result.success) {
        alert("เลื่อนวัน-เวลาเรียบร้อยแล้ว");
        location.reload();
      } else {
        alert("เกิดข้อผิดพลาด");
      }

    });

  });
</script>

</body>
</html>
